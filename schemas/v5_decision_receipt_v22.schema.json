{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v5.local/schemas/v5_decision_receipt_v22.schema.json",
  "title": "V5 Decision Receipt v2.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "decision_ts",
    "recorded_at",
    "market_data_cutoff",
    "strategy_id",
    "strategy_version",
    "parameter_lock_hash",
    "strategy_code_hash",
    "manifest_hash",
    "current_positions",
    "available_cash",
    "target_weights",
    "risk_checks",
    "gate_result",
    "risk_permission",
    "order_intents",
    "execution_mode",
    "final_action",
    "error_codes"
  ],
  "properties": {
    "schema_version": {"const": "v5_decision_receipt_v22.v1"},
    "receipt_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "decision_ts": {"type": "string", "format": "date-time"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "market_data_cutoff": {"type": "string", "format": "date-time"},
    "strategy_id": {"type": "string", "minLength": 1},
    "strategy_version": {"type": "string", "minLength": 1},
    "parameter_lock_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "strategy_code_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "manifest_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "current_positions": {"type": "array", "items": {"type": "object"}},
    "available_cash": {"type": "number", "minimum": 0},
    "target_weights": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "risk_checks": {"type": "array", "items": {"type": "object"}},
    "gate_result": {"type": "object"},
    "risk_permission": {"type": "string", "enum": ["ALLOW", "SELL_ONLY", "ABORT", "UNKNOWN"]},
    "order_intents": {"type": "array", "items": {"type": "object"}},
    "execution_mode": {"type": "string", "enum": ["READ_ONLY", "SHADOW", "PAPER", "LIVE"]},
    "final_action": {"type": "string", "minLength": 1},
    "error_codes": {"type": "array", "items": {"type": "string"}}
  }
}
