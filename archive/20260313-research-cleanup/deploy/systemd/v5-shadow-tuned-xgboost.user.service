[Unit]
Description=V5 shadow tuned XGBoost hourly dry-run
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/admin/clawd/v5-prod
Environment=PYTHONUNBUFFERED=1
Environment=V5_DATA_PROVIDER=okx
Environment=V5_LIVE_ARM=NO
Environment=V5_DISABLE_TOPLEVEL_ARTIFACTS=1
ExecStart=/usr/bin/flock -n /tmp/v5_shadow_tuned_xgboost_hourly.lock -c "/bin/bash -lc '/home/admin/clawd/v5-prod/scripts/run_shadow_tuned_xgboost_hourly.sh'"
