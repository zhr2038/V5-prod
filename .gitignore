data/sentiment_cache/
*.cache
.cache/

# Database files (runtime generated)
*.sqlite
*.sqlite3
*.db
reports/*.sqlite
reports/*.db

# Log files
*.log
logs/
.backup/

# Environment files
.env
.venv/
venv/
