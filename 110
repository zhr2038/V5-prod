400:                if audit:
401:                    audit.add_note(f"Fixed stop loss: {p.symbol} loss {loss_pct*100:.1f}%")
402:                continue  # Skip rank exit for this symbol
403:        
404:        # 3rd priority: 排名退出（只在未被利润/止损处理时）
