10:def _effective_deadband(base: float, cfg: AppConfig, audit: Optional[DecisionAudit]) -> float:
11:    """F3.1: widen deadband when daily budget exceeded (monitor-driven, controlled).
13:    Budget is computed in main() from persisted daily state; pipeline consumes audit.budget.
14:    """
15:    db = float(base)
16:    try:
17:        if not cfg.budget.action_enabled:
18:            return db
19:        b = (audit.budget or {}) if audit else {}
20:        if not b or not bool(b.get("exceeded")):
21:            return db
22:        mult = float(cfg.budget.deadband_multiplier_exceeded)
23:        cap = float(cfg.budget.deadband_cap)
24:        return float(min(db * mult, cap))
25:    except Exception:
26:        return db
