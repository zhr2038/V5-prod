351:            if not s or not s.close:
352:                continue
353:            current_price = float(s.close[-1])
354:            
355:            # 1st priority: 程序化利润管理（利润回撤锁盈）
356:            action, value, reason = self.profit_taking.evaluate(p.symbol, current_price)
357:            
358:            if action == 'sell_all' and float(p.qty) > 0:
359:                profit_orders.append(
360:                    Order(
361:                        symbol=p.symbol,
362:                        side="sell",
363:                        intent="CLOSE_LONG",
364:                        notional_usdt=float(p.qty) * current_price,
