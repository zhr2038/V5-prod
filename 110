406:        if hasattr(alpha, 'scores') and alpha.scores:
407:            sorted_scores = sorted(alpha.scores.items(), key=lambda x: x[1], reverse=True)
408:            symbol_ranks = {sym: idx+1 for idx, (sym, _) in enumerate(sorted_scores)}
