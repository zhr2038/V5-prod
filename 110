446:        
447:        # Merge all exit orders: profit first, then stop, then rank, then policy
448:        exit_orders = profit_orders + fixed_stop_orders + ranking_exit_orders + exit_orders
450:        # Deduplicate: keep only one exit per symbol per round, priority: sell_all > fixed_stop > atr > partial
451:        if exit_orders:
452:            prio_map = {
453:                'profit_taking_stop_loss_hit': 100,
454:                'fixed_stop_loss': 90,
455:                'atr_trailing': 80,
456:                'regime_exit': 70,
457:                'profit_partial': 60,
458:            }
459:            best = {}
460:            for o in exit_orders:
461:                reason = str((o.meta or {}).get('reason', ''))
462:                prio = 10
463:                for k, v in prio_map.items():
464:                    if reason.startswith(k):
465:                        prio = v
466:                        break
467:                cur = best.get(o.symbol)
468:                if cur is None or prio > cur[0]:
469:                    best[o.symbol] = (prio, o)
470:            exit_orders = [v[1] for v in best.values()]
471:        
472:        if audit:
473:            audit.counts["orders_exit"] = len(exit_orders)
474:            # capture detailed exit reasons for explainability
475:            xs = []
476:            for o in exit_orders:
477:                meta = o.meta or {}
478:                xs.append(
479:                    {
480:                        "symbol": o.symbol,
481:                        "side": o.side,
482:                        "intent": o.intent,
483:                        "reason": meta.get("reason"),
484:                        "last": meta.get("last") or o.signal_price,
485:                        "stop": meta.get("stop"),
486:                        "highest": meta.get("highest"),
487:                        "atr": meta.get("atr"),
488:                        "atr_mult": meta.get("atr_mult"),
489:                        "atr_n": meta.get("atr_n"),
490:                    }
491:                )
492:            audit.exit_signals = xs
494:        # 7. Rebalance orders生成（deadband + 拒绝原因审计）
495:        rebalance_orders: List[Order] = []
496:        router_decisions = []
497:        invalid_price_warnings: List[Dict] = []  # 记录价格无效的告警
499:        # Risk-Off 下是否进入 close-only：
500:        # 仅当策略明确将 risk_off 仓位倍数设为 0 时，才强制禁止 rebalance buy。
501:        # 这样可支持“Risk-Off 试探仓”（例如 pos_mult_risk_off=0.2）。
502:        regime_state_str = str(regime.state.value if hasattr(regime.state, 'value') else regime.state)
503:        risk_off_mult = float(getattr(self.cfg.regime, 'pos_mult_risk_off', 0.0))
504:        is_risk_off_close_only = (
505:            regime_state_str in ("Risk-Off", "Risk_Off", "RiskOff") and risk_off_mult <= 0.0
506:        )
507:        if is_risk_off_close_only and audit:
508:            audit.add_note("Risk-Off close-only: rebalance buy suppressed (pos_mult_risk_off<=0)")
510:        # deadband: adapt by regime
511:        rstate = str(regime.state.value if hasattr(regime.state, 'value') else regime.state)
512:        if rstate == "Trending":
513:            deadband_base = float(self.cfg.rebalance.deadband_trending)
514:        elif rstate in ("Risk-Off", "Risk_Off", "RiskOff"):
515:            deadband_base = float(self.cfg.rebalance.deadband_riskoff)
516:        else:
517:            deadband_base = float(self.cfg.rebalance.deadband_sideways)
519:        deadband = _effective_deadband(deadband_base, self.cfg, audit)
520:        if audit:
521:            audit.rebalance_deadband_pct = deadband
522:            # record budget action (F3.1)
523:            b = audit.budget or {}
524:            if b.get("exceeded") and self.cfg.budget.action_enabled:
525:                audit.budget_action = {
526:                    "enabled": True,
527:                    "trigger": b.get("reason") or "unknown",
528:                    "deadband_base": deadband_base,
529:                    "deadband_multiplier": float(self.cfg.budget.deadband_multiplier_exceeded),
530:                    "deadband_cap": float(self.cfg.budget.deadband_cap),
531:                    "deadband_effective": deadband,
532:                    "min_trade_notional_multiplier": 1.0,
533:                    "min_trade_notional_effective": None,
534:                    "suppressed_orders_count": 0,
535:                    "suppressed_reasons": [],
536:                }
537:            else:
538:                audit.budget_action = {"enabled": False}
540:        # current weights (with dust filtering)
541:        current_w: Dict[str, float] = {}
542:        # 灰尘阈值配置（提取到类级别常量）
543:        DUST_QTY_THRESHOLD = getattr(self.cfg.execution, 'dust_qty_threshold', 0.01)
544:        DUST_VALUE_THRESHOLD = getattr(self.cfg.execution, 'dust_value_threshold', 1.0)
545:        
546:        if equity > 0:
547:            for p in positions:
548:                pxp = float(prices.get(p.symbol, 0.0) or 0.0)
549:                if pxp <= 0:
550:                    continue
551:                
552:                # 灰尘过滤：数量太小或价值太低视为无持仓
553:                position_value = float(p.qty) * pxp
554:                if float(p.qty) < DUST_QTY_THRESHOLD or position_value < DUST_VALUE_THRESHOLD:
555:                    if audit and float(p.qty) > 0:
556:                        audit.add_note(f"Dust filter: {p.symbol} qty={p.qty:.8f} value=${position_value:.4f} treated as 0")
557:                    continue  # 跳过灰尘持仓
558:                
559:                current_w[p.symbol] = position_value / float(equity)
561:        cash_remaining = float(cash_usdt)
563:        # Rebalance should also handle symbols currently held but removed from target universe.
564:        # Iterate union(current positions, target weights). For symbols not in target, desired weight = 0.
565:        symbols_all = sorted(set(current_w.keys()) | set(target.keys()))
567:        for sym in symbols_all:
568:            tw = float(target.get(sym, 0.0))
569:            # deadband check on weight drift with banding: new position vs existing
570:            cw = float(current_w.get(sym, 0.0))
571:            drift = float(tw) - cw
572:            
573:            # Banding 逻辑：新建仓阈值 > 维持仓阈值
574:            # 判断是否是新建仓（当前权重接近0）
575:            eps = float(getattr(self.cfg.rebalance, "new_position_weight_eps", 0.001) or 0.001)
576:            is_new_position = cw < eps
578:            # 调整 deadband：新建仓需要更大的信号强度；清仓（tw≈0）允许更小 deadband 以加速清理
579:            effective_deadband = deadband
580:            if is_new_position:
581:                mult = float(getattr(self.cfg.rebalance, "new_position_deadband_multiplier", 2.0) or 2.0)
582:                effective_deadband = deadband * mult
583:                if audit:
584:                    audit.add_note(f"Banding: {sym} is new position, deadband {deadband}→{effective_deadband:.3f}")
586:            # If target weight is ~0 (close-only), shrink deadband (but keep sells allowed) to avoid stuck dust positions.
587:            try:
588:                tw_eps = float(getattr(self.cfg.rebalance, "close_only_weight_eps", 0.001) or 0.001)
589:                if abs(float(tw)) <= tw_eps and abs(float(cw)) > tw_eps:
590:                    # 清仓模式：死区大幅降低，确保能卖出
591:                    cm = float(getattr(self.cfg.rebalance, "close_only_deadband_multiplier", 0.1) or 0.1)  # 0.5->0.1
592:                    effective_deadband = min(float(effective_deadband), float(deadband) * float(cm))
593:                    if audit:
594:                        audit.add_note(f"Close-only: {sym} tw≈0, deadband {deadband}→{effective_deadband:.3f} (force exit)")
595:            except Exception:
596:                pass
597:            
598:            if audit:
599:                audit.rebalance_drift_by_symbol[sym] = drift
600:                audit.rebalance_effective_deadband_by_symbol[sym] = effective_deadband
601:            
602:            if abs(drift) <= effective_deadband:
603:                if audit:
604:                    audit.rebalance_skipped_deadband_count += 1
605:                    audit.rebalance_skipped_deadband_by_symbol[sym] = abs(drift)
606:                    audit.reject("deadband_skip")
607:                    router_decisions.append({
608:                        "symbol": sym,
609:                        "action": "skip",
610:                        "reason": "deadband",
611:                        "drift": drift,
612:                        "deadband": effective_deadband,
613:                        "is_new_position": is_new_position,
614:                    })
615:                continue
617:            px = float(prices.get(sym, 0.0) or 0.0)
618:            if px <= 0:
619:                if audit:
620:                    audit.reject("no_closed_bar")
621:                # 记录价格无效告警
622:                invalid_price_warnings.append({
623:                    "symbol": sym,
624:                    "timestamp": datetime.utcnow().isoformat(),
625:                    "reason": "price_invalid_or_missing"
626:                })
627:                continue
628:            
629:            held = next((p for p in positions if p.symbol == sym and p.qty > 0), None)
631:            # P0 FIX: Risk-Off close-only 模式：跳过所有买入型的 rebalance
632:            if is_risk_off_close_only and drift > 0:
633:                if audit:
634:                    audit.reject("risk_off_close_only")
635:                    router_decisions.append({
636:                        "symbol": sym,
637:                        "action": "skip",
638:                        "reason": "risk_off_close_only",
639:                        "drift": drift,
640:                    })
641:                continue
643:            # If symbol is removed from target universe but currently held, generate a sell to reduce drift.
644:            # P0 FIX: 统一逻辑：根据 drift 符号决定买卖方向
645:            if drift < 0:
646:                # 需要减仓/清仓
647:                side = "sell"
648:                intent = "REBALANCE"
649:                # P0 FIX: notional 用 delta 计算
650:                notional = abs(float(drift)) * float(equity)
651:                if notional <= 0:
652:                    continue
653:            else:
654:                # drift > 0，需要加仓
655:                side = "buy"
656:                intent = "OPEN_LONG" if held is None else "REBALANCE"
657:                # P0 FIX: notional 用 delta 计算
658:                notional = abs(float(drift)) * float(equity)
659:                if notional <= 0:
660:                    continue
661:            
662:            # Router check: min_notional (base + F3.2 stage-2)
663:            min_notional = float(self.cfg.budget.min_trade_notional_base)
664:            if audit and (audit.budget or {}).get("exceeded") and self.cfg.budget.action_enabled:
665:                try:
666:                    from src.core.budget_action import effective_min_trade_notional
668:                    eff, patch = effective_min_trade_notional(self.cfg, audit)
669:                    min_notional = float(eff)
670:                    # merge patch into budget_action
671:                    ba = audit.budget_action or {}
672:                    ba.update(patch)
673:                    audit.budget_action = ba
674:                except Exception:
675:                    pass
677:            # Borrow-prevention filter (live): skip opening high-risk low-price meme coins.
678:            # - allow sells to exit/clean up positions
679:            if side == "buy" and bool(getattr(self.cfg.execution, "borrow_prevention", False)):
680:                rules = _load_borrow_prevention_rules(str(getattr(self.cfg.execution, "high_risk_blacklist_path", "configs/borrow_prevention_rules.json")))
681:                mp = _min_price_usdt(rules=rules)
682:                if _is_high_risk_symbol(sym, rules=rules):
683:                    if audit:
684:                        audit.reject("high_risk_symbol")
685:                        router_decisions.append({"symbol": sym, "action": "skip", "reason": "high_risk_symbol"})
686:                    continue
687:                if mp is not None and float(px) < float(mp):
688:                    if audit:
689:                        audit.reject("min_price")
690:                        router_decisions.append({"symbol": sym, "action": "skip", "reason": f"min_price<{mp}", "px": px})
691:                    continue
693:            # Exchange min-order filter (symbol-specific): avoid placing orders that the exchange will reject.
694:            # Uses OKX instrument minSz (base qty) to estimate a minimum USDT notional.
695:            if side == "buy" and bool(getattr(self.cfg.budget, "exchange_min_notional_enabled", True)):
696:                try:
697:                    from src.data.okx_instruments import OKXSpotInstrumentsCache
699:                    spec = OKXSpotInstrumentsCache().get_spec(symbol_to_inst_id(sym))
700:                    if spec is not None:
701:                        min_sz = float(spec.min_sz or 0.0)
702:                        # Estimate min notional requirement from base minSz.
703:                        min_notional_ex = float(min_sz) * float(px)
704:                        slack = float(getattr(self.cfg.budget, "exchange_min_notional_slack_multiplier", 1.05) or 1.05)
705:                        if min_notional_ex > 0 and float(notional) < float(min_notional_ex) * slack:
706:                            if audit:
707:                                audit.reject("exchange_min_notional")
708:                                router_decisions.append(
709:                                    {
710:                                        "symbol": sym,
711:                                        "action": "skip",
712:                                        "reason": "exchange_min_notional",
713:                                        "notional": float(notional),
714:                                        "min_notional_ex": float(min_notional_ex),
715:                                        "min_sz": float(min_sz),
716:                                        "px": float(px),
717:                                        "slack": float(slack),
718:                                    }
719:                                )
720:                            continue
721:                except Exception:
722:                    pass
724:            # Min-notional filter: apply to buys; allow sells (especially for removed symbols) to reduce drift.
725:            if side == "buy" and notional < float(min_notional):
726:                if audit:
727:                    audit.reject("min_notional")
728:                    router_decisions.append(
729:                        {
730:                            "symbol": sym,
731:                            "action": "skip",
732:                            "reason": "min_notional",
733:                            "notional": notional,
734:                            "min_notional": float(min_notional),
735:                        }
736:                    )
737:                    # budget_action suppression stats
738:                    try:
739:                        ba = audit.budget_action or {}
740:                        if ba.get("enabled"):
741:                            ba.setdefault("suppressed_reasons", [])
742:                            if "min_notional" not in ba["suppressed_reasons"]:
743:                                ba["suppressed_reasons"].append("min_notional")
744:                            ba["suppressed_orders_count"] = int(ba.get("suppressed_orders_count") or 0) + 1
745:                            sbs = ba.get("suppressed_by_symbol") or {}
746:                            sbs[sym] = float(notional)
747:                            ba["suppressed_by_symbol"] = sbs
748:                            audit.budget_action = ba
749:                    except Exception:
750:                        pass
751:                continue
752:            
753:            # 检查cash是否足够（按批次累计扣减，避免多单同时通过导致超额下单）
754:            if notional > cash_remaining:
755:                if audit:
756:                    audit.reject("insufficient_cash")
757:                    router_decisions.append(
758:                        {
759:                            "symbol": sym,
760:                            "action": "skip",
761:                            "reason": "insufficient_cash",
762:                            "notional": notional,
763:                            "cash_available": cash_remaining,
764:                            "cash_initial": float(cash_usdt),
765:                        }
766:                    )
767:                continue
768:            
769:            # 如果通过所有检查，生成订单
770:            meta = {"target_w": tw, "dd_mult": dd_mult}
771:            if audit:
772:                meta.update(
773:                    {
774:                        "regime": audit.regime,
775:                        "window_start_ts": audit.window_start_ts,
776:                        "window_end_ts": audit.window_end_ts,
777:                        "deadband_pct": audit.rebalance_deadband_pct,
778:                        "drift": drift,
779:                    }
780:                )
782:            rebalance_orders.append(
783:                Order(
784:                    symbol=sym,
785:                    side=side,
786:                    intent=intent,
787:                    notional_usdt=notional,
788:                    signal_price=px,
789:                    meta=meta,
790:                )
791:            )
793:            # 买入订单：注册止损和利润管理
794:            if side == "buy":
795:                self.fixed_stop_loss.register_position(sym, px)
796:                self.profit_taking.register_position(sym, px)  # 注册利润管理
797:                if audit:
798:                    stop_pct = self.fixed_stop_loss.config.get_stop_pct(sym)
799:                    audit.add_note(f"Fixed stop registered: {sym} @ {px:.4f}, stop @ {px*(1-stop_pct):.4f}")
801:            # Update batch cash budget.
802:            if side == "buy":
803:                cash_remaining -= float(notional)
804:            else:
805:                cash_remaining += float(notional)
807:            if audit:
808:                router_decisions.append(
809:                    {
810:                        "symbol": sym,
811:                        "action": "create",
812:                        "reason": "ok",
813:                        "side": side,
814:                        "notional": notional,
815:                        "cash_after": cash_remaining,
816:                    }
817:                )
818:        
819:        if audit:
820:            audit.router_decisions = router_decisions
821:            audit.counts["orders_rebalance"] = len(rebalance_orders)
822:            # fill budget_action suppression stats (F3.1)
823:            try:
824:                ba = audit.budget_action or {}
825:                if ba.get("enabled"):
826:                    ba["suppressed_orders_count"] = int(audit.rebalance_skipped_deadband_count)
827:                    ba["suppressed_reasons"] = ["deadband"] if audit.rebalance_skipped_deadband_count > 0 else []
828:                    audit.budget_action = ba
829:            except Exception:
830:                pass
832:        if run_logger is not None:
833:            try:
834:                now_ts = self.clock.now().isoformat().replace("+00:00", "Z")
835:                run_logger.log_equity({
836:                    "ts": now_ts,
837:                    # Reporting (raw) vs sizing (capped)
838:                    "cash": float(cash_raw),
839:                    "equity": float(equity_raw),
840:                    "cash_sizing": float(cash_usdt),
841:                    "equity_sizing": float(equity),
842:                    "equity_cap_usdt": float(getattr(self.cfg.budget, "live_equity_cap_usdt", 0.0) or 0.0) if getattr(self.cfg.budget, "live_equity_cap_usdt", None) is not None else None,
843:                    "peak": float(pst.peak_equity_usdt),
844:                    "dd": float(pst.drawdown_pct),
845:                    "exposure_mult": float(dd_mult),
846:                })
847:                for p in positions:
848:                    run_logger.log_position({
849:                        "ts": now_ts,
850:                        "symbol": p.symbol,
851:                        "qty": float(p.qty),
852:                        "avg_px": float(p.avg_px),
853:                        "mark_px": float(getattr(p, 'last_mark_px', 0.0) or prices.get(p.symbol, 0.0)),
854:                        "highest_px": float(getattr(p, 'highest_px', 0.0)),
855:                        "unrealized_pnl_pct": float(getattr(p, 'unrealized_pnl_pct', 0.0)),
856:                    })
857:            except Exception:
858:                pass
860:        # Phase 3: ML数据收集
861:        # 收集特征快照用于训练ML模型
862:        try:
863:            current_ts = int(self.clock.now().timestamp() * 1000)
864:            for sym in symbols_all:
865:                if sym in market_data_1h:
866:                    px = float(prices.get(sym, 0))
867:                    if px > 0:
868:                        self.data_collector.collect_features(
869:                            timestamp=current_ts,
870:                            symbol=sym,
871:                            market_data={
872:                                'close': list(market_data_1h[sym].close) if hasattr(market_data_1h[sym], 'close') else [px],
873:                                'high': list(market_data_1h[sym].high) if hasattr(market_data_1h[sym], 'high') else [px],
874:                                'low': list(market_data_1h[sym].low) if hasattr(market_data_1h[sym], 'low') else [px],
875:                                'volume': list(market_data_1h[sym].volume) if hasattr(market_data_1h[sym], 'volume') else [0],
876:                            },
877:                            regime=str(regime.state.value if hasattr(regime.state, 'value') else regime.state)
878:                        )
879:            
880:            # 回填6小时前的标签
881:            filled_count = self.data_collector.fill_labels(current_ts)
882:            if audit and filled_count > 0:
883:                audit.add_note(f"ML data: filled {filled_count} labels")
884:        except Exception as e:
885:            # 数据收集失败不应影响交易
886:            if audit:
887:                audit.add_note(f"ML data collection skipped: {str(e)[:50]}")
889:        orders = exit_orders + rebalance_orders
890:        
891:        # 输出价格无效警告（如果有）
892:        if invalid_price_warnings and run_logger:
893:            run_logger.warning(f"[Pipeline] {len(invalid_price_warnings)} symbols have invalid prices: " + 
894:                             ", ".join([w['symbol'] for w in invalid_price_warnings[:5]]))
895:        
896:        return PipelineOutput(alpha=alpha, regime=regime, portfolio=portfolio, orders=orders)
