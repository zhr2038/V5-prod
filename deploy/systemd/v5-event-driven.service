[Unit]
Description=V5 event-driven trading check
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/admin/clawd/v5-trading-bot
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/flock -n /tmp/v5_event_driven.lock -c "/bin/bash -lc 'PYTHONPATH=. /home/admin/clawd/v5-trading-bot/.venv/bin/python /home/admin/clawd/v5-trading-bot/event_driven_check.py'"
