[Unit]
Description=V5 tuned XGBoost shadow hourly evaluation (research-only; disabled in live_prod)
Wants=network-online.target
After=network-online.target
# Shadow tuned XGBoost is kept for offline research and is not active in live_prod.
# Create /etc/v5-enable-ml-research-timers only for an explicit research host opt-in.
ConditionPathExists=/etc/v5-enable-ml-research-timers

[Service]
Type=oneshot
WorkingDirectory=/home/admin/clawd/v5-shadow-tuned-xgboost
Environment=PYTHONUNBUFFERED=1
Environment=V5_DATA_PROVIDER=okx
Environment=V5_LIVE_ARM=NO
Environment=V5_WORKSPACE=/home/admin/clawd/v5-shadow-tuned-xgboost
ExecStart=/usr/bin/flock -n /tmp/v5_shadow_tuned_xgboost_hourly.lock -c "/bin/bash -lc '/home/admin/clawd/v5-shadow-tuned-xgboost/scripts/run_shadow_tuned_xgboost_hourly.sh'"
