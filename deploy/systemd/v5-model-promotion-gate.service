[Unit]
Description=V5 ML Model Promotion Gate (research-only; disabled in live_prod)
Wants=network-online.target
After=network-online.target v5-daily-ml-training.service
# ML promotion is kept for offline research and is not active in live_prod.
# Create /etc/v5-enable-ml-research-timers only for an explicit research host opt-in.
ConditionPathExists=/etc/v5-enable-ml-research-timers

[Service]
Type=oneshot
WorkingDirectory=/home/ubuntu/clawd/v5-prod
SuccessExitStatus=2
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/home/ubuntu/clawd/v5-prod
Environment=V5_WORKSPACE=/home/ubuntu/clawd/v5-prod
Environment=V5_CONFIG=configs/live_prod.yaml
ExecStart=/bin/bash -lc 'cd /home/ubuntu/clawd/v5-prod && source .venv/bin/activate && python scripts/model_promotion_gate.py'

[Install]
WantedBy=default.target
