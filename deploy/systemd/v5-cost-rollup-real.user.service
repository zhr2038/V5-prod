[Unit]
Description=V5: rollup real (okx_fill) cost stats + anomaly check

[Service]
Type=oneshot
WorkingDirectory=/home/admin/clawd/v5-trading-bot
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'cd /home/admin/clawd/v5-trading-bot && /home/admin/clawd/v5-trading-bot/.venv/bin/python scripts/rollup_costs.py --day $(date -u +%%Y%%m%%d) --base_dir reports/cost_events --out_dir reports/cost_stats_real --source okx_fill --check_anomaly'
