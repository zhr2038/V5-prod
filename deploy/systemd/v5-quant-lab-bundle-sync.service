[Unit]
Description=Sync cloud quant-lab pack when available; observe NAS-only packs without proxying
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/clawd/v5-prod
ExecStart=/home/ubuntu/clawd/v5-prod/.venv/bin/python scripts/sync_quant_lab_latest_bundle.py
NoNewPrivileges=true
PrivateTmp=true
