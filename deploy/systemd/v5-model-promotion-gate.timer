[Unit]
Description=Run V5 ML Promotion Gate at 00:40 (research-only; disabled in live_prod)
# ML promotion is kept for offline research and is not active in live_prod.
# Create /etc/v5-enable-ml-research-timers only for an explicit research host opt-in.
ConditionPathExists=/etc/v5-enable-ml-research-timers

[Timer]
OnCalendar=*-*-* 00:40:00
Persistent=true
AccuracySec=60s
RandomizedDelaySec=120s
Unit=v5-model-promotion-gate.service

[Install]
WantedBy=timers.target
