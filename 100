50:    def export_and_train(self):
51:        """导出数据并训练模型"""
52:        self.log("="*60)
53:        self.log("Starting Daily ML Training")
54:        self.log("="*60)
55:        
56:        # 1. 检查数据充足性
57:        is_ready, stats = self.check_data_sufficiency(min_samples=100)
58:        
59:        if not is_ready:
60:            self.log(f"⚠️  Insufficient data: {stats['labeled_records']} < 100 samples")
61:            self.log("Waiting for more data...")
62:            return False
63:        
64:        # 2. 导出训练数据
65:        self.log("\nExporting training data...")
66:        csv_path = "reports/ml_training_data.csv"
67:        
68:        success = self.collector.export_training_data(csv_path, min_samples=100)
69:        if not success:
70:            self.log("❌ Failed to export training data")
71:            return False
72:        
73:        # 3. 加载数据
74:        self.log("\nLoading training data...")
75:        df = pd.read_csv(csv_path)
76:        
77:        # 准备特征和目标 - 使用清理后的特征（移除泄露和高相关特征）
78:        feature_cols = [
79:            'returns_24h',      # 只保留长周期收益
80:            'momentum_5d',
81:            'momentum_20d',
82:            'volatility_24h',   # 只保留长周期波动率
83:            'volume_ratio',
84:            'obv',
85:            'rsi',
86:            'macd',
87:            'macd_signal',
88:            'bb_position',
89:            'price_position',
90:        ]
91:        
92:        # 只保留存在的列
93:        feature_cols = [c for c in feature_cols if c in df.columns]
94:        
95:        # 删除NaN
96:        df = df.dropna(subset=feature_cols + ['future_return_6h'])
97:        
98:        if len(df) < 100:
99:            self.log(f"❌ Insufficient valid samples after cleaning: {len(df)}")
100:            return False
101:        
102:        X = df[feature_cols]
103:        y = df['future_return_6h']
104:        
105:        self.log(f"Training samples: {len(X)}")
106:        self.log(f"Features: {len(feature_cols)}")
107:        
108:        # 4. 时间序列分割 - 确保按时间顺序分割
109:        df = df.sort_values('timestamp').reset_index(drop=True)
110:        split_idx = int(len(df) * 0.8)
111:        X_train, X_valid = X.iloc[:split_idx], X.iloc[split_idx:]
112:        y_train, y_valid = y.iloc[:split_idx], y.iloc[split_idx:]
113:        
114:        # 检查时间分割是否合理
115:        train_time_end = df.iloc[split_idx-1]['timestamp']
116:        valid_time_start = df.iloc[split_idx]['timestamp']
117:        self.log(f"Train time range: {df.iloc[0]['timestamp']} - {train_time_end}")
118:        self.log(f"Valid time range: {valid_time_start} - {df.iloc[-1]['timestamp']}")
119:        
120:        self.log(f"Train: {len(X_train)}, Valid: {len(X_valid)}")
121:        
122:        # 5. 训练模型 - 使用Ridge回归防过拟合
123:        self.log("\nTraining Ridge Regression model...")
124:        
125:        config = MLFactorConfig(
126:            model_type='ridge',
127:            alpha=10.0
128:        )
129:        
130:        model = MLFactorModel(config)
131:        
132:        try:
133:            model.train(X_train, y_train, X_valid, y_valid)
134:        except Exception as e:
135:            self.log(f"❌ Training failed: {e}")
136:            return False
137:        
138:        # 6. 评估模型
139:        train_pred = model.predict_batch(X_train)
140:        valid_pred = model.predict_batch(X_valid)
141:        
142:        train_ic = df.iloc[:split_idx]['future_return_6h'].corr(train_pred)
143:        valid_ic = df.iloc[split_idx:]['future_return_6h'].corr(valid_pred)
144:        
145:        self.log(f"\nModel Performance:")
146:        self.log(f"  Train IC: {train_ic:.4f}")
147:        self.log(f"  Valid IC: {valid_ic:.4f}")
148:        
149:        # 判断模型是否有效 - 对于小数据集适当放宽
150:        ic_gap = train_ic - valid_ic
151:        if valid_ic < -0.1:  # 验证IC不能太差
152:            self.log(f"⚠️  Model validation IC too low ({valid_ic:.4f}), not saving")
153:            return False
154:        if ic_gap > 0.9:  # 训练/验证差距过大才认为是严重过拟合
155:            self.log(f"⚠️  Model overfitting detected (gap={ic_gap:.4f}), not saving")
156:            return False
157:        
158:        # 7. 保存模型
159:        self.log(f"\nSaving model to {self.model_path}...")
160:        model.save_model(str(self.model_path))
161:        
162:        # 8. 记录训练历史
163:        history = {
164:            'timestamp': datetime.now().isoformat(),
165:            'samples': len(df),
166:            'train_ic': float(train_ic),
167:            'valid_ic': float(valid_ic),
168:            'config': config.__dict__
169:        }
170:        
171:        history_file = Path("reports/ml_training_history.json")
172:        histories = []
173:        if history_file.exists():
174:            with open(history_file, 'r') as f:
175:                histories = json.load(f)
