39:    def check_data_sufficiency(self, min_samples=100):
40:        """检查数据是否足够"""
41:        stats = self.collector.get_statistics()
42:        
43:        self.log(f"Data Statistics:")
44:        self.log(f"  Total records: {stats['total_records']}")
45:        self.log(f"  Labeled records: {stats['labeled_records']}")
46:        self.log(f"  Unique symbols: {stats['num_symbols']}")
47:        
48:        return stats['labeled_records'] >= min_samples, stats
